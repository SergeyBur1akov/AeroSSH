<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FF161B22" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠️ Unknown Host" android:textSize="20sp" android:textStyle="bold" android:textColor="#FFD29922" android:layout_marginBottom="12dp" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="The authenticity of this host can't be established." android:textSize="14sp" android:textColor="#FF8B949E" android:layout_marginBottom="16dp" />
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FF21262D" android:padding="12dp" android:layout_marginBottom="16dp">
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
            <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Host:" android:textSize="13sp" android:textColor="#FF8B949E" android:fontFamily="monospace" />
            <TextView android:id="@+id/hostText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#FFE6EDF3" android:fontFamily="monospace" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
            <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="Type:" android:textSize="13sp" android:textColor="#FF8B949E" android:fontFamily="monospace" />
            <TextView android:id="@+id/keyTypeText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#FFE6EDF3" android:fontFamily="monospace" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:layout_width="80dp" android:layout_height="wrap_content" android:text="SHA256:" android:textSize="13sp" android:textColor="#FF8B949E" android:fontFamily="monospace" />
            <TextView android:id="@+id/fingerprintText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#FF58A6FF" android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end">
        <Button android:id="@+id/btnReject" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reject" android:textColor="#FFF85149" />
        <Button android:id="@+id/btnTrust" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trust & Connect" android:textColor="#FF0D1117" android:backgroundTint="#FF3FB950" android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
