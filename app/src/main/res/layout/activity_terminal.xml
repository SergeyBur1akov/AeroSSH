<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FF0D1117">
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="44dp" android:background="#FF161B22" android:gravity="center_vertical" android:paddingHorizontal="12dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_revert" android:scaleType="centerInside" android:tint="#FF8B949E" />
        <LinearLayout android:orientation="vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginHorizontal="8dp">
            <TextView android:id="@+id/titleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="14sp" android:textStyle="bold" android:textColor="#FFE6EDF3" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/subtitleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="11sp" android:textColor="#FF8B949E" android:fontFamily="monospace" />
        </LinearLayout>
        <ImageButton android:id="@+id/btnNewSession" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_add" android:scaleType="centerInside" android:tint="#FF8B949E" />
        <ImageButton android:id="@+id/btnSftp" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_save" android:scaleType="centerInside" android:tint="#FF3FB950" android:layout_marginStart="4dp" />
        <ImageButton android:id="@+id/btnDisconnect" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_close_clear_cancel" android:scaleType="centerInside" android:tint="#FFF85149" android:layout_marginStart="4dp" />
    </LinearLayout>
    <HorizontalScrollView android:id="@+id/tabsScroll" android:layout_width="match_parent" android:layout_height="36dp" android:background="#FF0D1117" android:scrollbars="none" android:fillViewport="true">
        <LinearLayout android:id="@+id/tabsContainer" android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center_vertical" android:paddingHorizontal="4dp" />
    </HorizontalScrollView>
    <com.companyname.aerossh.TerminalView android:id="@+id/terminalView" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FF21262D" android:scrollbars="none">
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content" android:layout_height="40dp" android:paddingVertical="4dp" android:paddingHorizontal="6dp">
            <TextView android:id="@+id/keyTab" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="TAB" android:textSize="12sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" android:fontFamily="monospace" />
            <TextView android:id="@+id/keyEsc" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="ESC" android:textSize="12sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" android:fontFamily="monospace" />
            <TextView android:id="@+id/keyCtrl" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="CTRL" android:textSize="12sp" android:textColor="#FF58A6FF" android:background="@drawable/key_ctrl_bg" android:layout_marginEnd="4dp" android:fontFamily="monospace" />
            <TextView android:id="@+id/keyUp" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="▲" android:textSize="14sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/keyDown" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="▼" android:textSize="14sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/keyLeft" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="◄" android:textSize="14sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/keyRight" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="►" android:textSize="14sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/keyHome" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="HOME" android:textSize="12sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" android:fontFamily="monospace" />
            <TextView android:id="@+id/keyEnd" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="END" android:textSize="12sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" android:fontFamily="monospace" />
            <TextView android:id="@+id/keyPgUp" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="PG↑" android:textSize="12sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" android:layout_marginEnd="4dp" />
            <TextView android:id="@+id/keyPgDn" android:layout_width="wrap_content" android:layout_height="match_parent" android:gravity="center" android:paddingHorizontal="14dp" android:text="PG↓" android:textSize="12sp" android:textColor="#FFE6EDF3" android:background="@drawable/key_bg" />
        </LinearLayout>
    </HorizontalScrollView>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="38dp" android:background="#FF0D1117" android:gravity="center_vertical" android:paddingHorizontal="4dp">
        <TextView android:id="@+id/symPipe" style="@style/SymbolKey" android:text="|" />
        <TextView android:id="@+id/symSlash" style="@style/SymbolKey" android:text="/" />
        <TextView android:id="@+id/symBackslash" style="@style/SymbolKey" android:text="\\" />
        <TextView android:id="@+id/symDash" style="@style/SymbolKey" android:text="-" />
        <TextView android:id="@+id/symUnderscore" style="@style/SymbolKey" android:text="_" />
        <TextView android:id="@+id/symTilde" style="@style/SymbolKey" android:text="~" />
        <TextView android:id="@+id/symAt" style="@style/SymbolKey" android:text="@" />
        <TextView android:id="@+id/symDot" style="@style/SymbolKey" android:text="." />
        <TextView android:id="@+id/symColon" style="@style/SymbolKey" android:text=":" />
        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <TextView android:id="@+id/symCtrlC" style="@style/SymbolKey" android:text="^C" android:textColor="#FFF85149" />
        <TextView android:id="@+id/symCtrlD" style="@style/SymbolKey" android:text="^D" android:textColor="#FFD29922" />
        <TextView android:id="@+id/symCtrlZ" style="@style/SymbolKey" android:text="^Z" android:textColor="#FFD29922" />
        <TextView android:id="@+id/symCtrlL" style="@style/SymbolKey" android:text="^L" android:textColor="#FF3FB950" />
    </LinearLayout>
    <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="52dp" android:background="#FF161B22" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <EditText android:id="@+id/inputField" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@null" android:textColor="#FFE6EDF3" android:textColorHint="#FF484F58" android:textSize="15sp" android:fontFamily="monospace" android:hint="Type command..." android:singleLine="true" android:imeOptions="actionSend" android:inputType="textNoSuggestions" android:paddingHorizontal="8dp" />
        <ImageButton android:id="@+id/btnSend" android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/send_button_bg" android:src="@android:drawable/ic_menu_send" android:scaleType="centerInside" android:tint="#FF0D1117" />
    </LinearLayout>
</LinearLayout>
