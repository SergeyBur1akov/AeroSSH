<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FF0D1117" android:fillViewport="true">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Appearance" android:textSize="13sp" android:textColor="#FF58A6FF" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="12dp" />
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Theme" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <Spinner android:id="@+id/themeSpinner" android:layout_width="wrap_content" android:layout_height="40dp" android:entries="@array/themes" android:background="@drawable/edit_text_dark" />
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terminal" android:textSize="13sp" android:textColor="#FF58A6FF" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginTop="16dp" android:layout_marginBottom="12dp" />
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Font Size" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <TextView android:id="@+id/fontSizeValue" android:layout_width="48dp" android:layout_height="wrap_content" android:text="14sp" android:textSize="14sp" android:textColor="#FF8B949E" android:fontFamily="monospace" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/fontSizeSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progressTint="#FF58A6FF" android:thumbTint="#FF58A6FF" android:layout_marginBottom="12dp" />
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Line Spacing" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <TextView android:id="@+id/lineSpacingValue" android:layout_width="48dp" android:layout_height="wrap_content" android:text="1.3x" android:textSize="14sp" android:textColor="#FF8B949E" android:fontFamily="monospace" android:gravity="end" />
        </LinearLayout>
        <SeekBar android:id="@+id/lineSpacingSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progressTint="#FF58A6FF" android:thumbTint="#FF58A6FF" android:layout_marginBottom="12dp" />
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Scrollback" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <Spinner android:id="@+id/scrollbackSpinner" android:layout_width="wrap_content" android:layout_height="40dp" android:entries="@array/scrollback_options" android:background="@drawable/edit_text_dark" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cursor" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <Spinner android:id="@+id/cursorSpinner" android:layout_width="wrap_content" android:layout_height="40dp" android:entries="@array/cursor_styles" android:background="@drawable/edit_text_dark" />
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connection" android:textSize="13sp" android:textColor="#FF58A6FF" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginTop="16dp" android:layout_marginBottom="12dp" />
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Timeout" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <Spinner android:id="@+id/timeoutSpinner" android:layout_width="wrap_content" android:layout_height="40dp" android:entries="@array/timeout_options" android:background="@drawable/edit_text_dark" />
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Encoding" android:textSize="15sp" android:textColor="#FFE6EDF3" />
            <Spinner android:id="@+id/encodingSpinner" android:layout_width="wrap_content" android:layout_height="40dp" android:entries="@array/encodings" android:background="@drawable/edit_text_dark" />
        </LinearLayout>
        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/keepaliveSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Keepalive (30s)" android:textSize="15sp" android:textColor="#FFE6EDF3" android:layout_marginBottom="8dp" />
        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/autoReconnectSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Auto-reconnect" android:textSize="15sp" android:textColor="#FFE6EDF3" android:layout_marginBottom="8dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Security" android:textSize="13sp" android:textColor="#FF58A6FF" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginTop="16dp" android:layout_marginBottom="12dp" />
        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/logSwitch" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Log sessions" android:textSize="15sp" android:textColor="#FFE6EDF3" android:layout_marginBottom="12dp" />
        <Button android:id="@+id/exportBtn" android:layout_width="match_parent" android:layout_height="48dp" android:text="Export Logs" android:textColor="#FFE6EDF3" android:backgroundTint="#FF30363D" android:layout_marginBottom="12dp" />
        <Button android:id="@+id/btnChangePassword" android:layout_width="match_parent" android:layout_height="48dp" android:text="Change Password" android:textColor="#FFE6EDF3" android:backgroundTint="#FF30363D" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/btnWipeData" android:layout_width="match_parent" android:layout_height="48dp" android:text="⚠ Wipe All Data" android:textColor="#FFF85149" android:backgroundTint="#FF21262D" android:layout_marginBottom="24dp" />
    </LinearLayout>
</ScrollView>
