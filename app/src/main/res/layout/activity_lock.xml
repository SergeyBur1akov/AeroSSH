<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#FF0D1117">

    <!-- Main lock screen -->
    <LinearLayout android:id="@+id/lockScreen" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:padding="32dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔒" android:textSize="64sp" android:layout_marginBottom="16dp" />
        <TextView android:id="@+id/titleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AeroSSH" android:textSize="28sp" android:textStyle="bold" android:textColor="#FFE6EDF3" android:fontFamily="sans-serif-medium" android:letterSpacing="0.08" android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/subtitleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Enter password to unlock" android:textSize="14sp" android:textColor="#FF8B949E" android:layout_marginBottom="32dp" />
        <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:hint="Password" app:hintTextColor="#FF8B949E" app:boxBackgroundColor="#FF161B22" app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp" app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp" app:startIconDrawable="@android:drawable/ic_lock_idle_lock" app:startIconTint="#FF8B949E" xmlns:app="http://schemas.android.com/apk/res-auto">
            <com.google.android.material.textfield.TextInputEditText android:id="@+id/passwordInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFE6EDF3" android:textColorHint="#FF484F58" android:inputType="textPassword" android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>
        <LinearLayout android:id="@+id/confirmRow" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:visibility="gone">
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Confirm password" app:hintTextColor="#FF8B949E" app:boxBackgroundColor="#FF161B22" app:boxCornerRadiusTopStart="12dp" app:boxCornerRadiusTopEnd="12dp" app:boxCornerRadiusBottomStart="12dp" app:boxCornerRadiusBottomEnd="12dp" xmlns:app="http://schemas.android.com/apk/res-auto">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/confirmInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFE6EDF3" android:textColorHint="#FF484F58" android:inputType="textPassword" android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <Button android:id="@+id/btnAction" android:layout_width="match_parent" android:layout_height="56dp" android:text="Unlock" android:textSize="16sp" android:textAllCaps="false" android:textStyle="bold" android:textColor="#FF0D1117" android:backgroundTint="#FF58A6FF" android:layout_marginBottom="16dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AES-256-GCM • PBKDF2 600K • StrongBox" android:textSize="11sp" android:textColor="#FF484F58" android:fontFamily="monospace" android:gravity="center" />
    </LinearLayout>

    <!-- Decrypting animation overlay -->
    <LinearLayout android:id="@+id/decryptOverlay" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:background="#FF0D1117" android:visibility="gone">
        <com.companyname.aerossh.ui.DecryptAnimationView android:id="@+id/decryptAnim" android:layout_width="280dp" android:layout_height="280dp" android:layout_marginBottom="24dp" />
        <TextView android:id="@+id/decryptStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="13sp" android:textColor="#FF58A6FF" android:fontFamily="monospace" android:layout_marginTop="8dp" />
        <TextView android:id="@+id/decryptDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="11sp" android:textColor="#FF484F58" android:fontFamily="monospace" android:layout_marginTop="4dp" />
    </LinearLayout>

</FrameLayout>
